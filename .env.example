# Optional: Hugging Face Hub token for higher rate limits and reliable downloads.
# Create a token at https://huggingface.co/settings/tokens
# Copy this file to `.env` and set your value (`.env` is gitignored).
HF_TOKEN=

# Optional model device override for PyTorch-backed local models.
# On Apple Silicon, use `mps` for the Mac GPU. There is no PyTorch `mpx` device.
# On an AMD ROCm PyTorch build, use `rocm` (internally PyTorch calls it `cuda`).
# Applies to: Layer 1 Presidio spaCy, Layer 2 HuggingFace models,
# sentence-transformer embeddings, and the reranker.
# CUDA on Windows/Linux requires cupy-cuda12x (installed by requirements.txt).
# AMD: install a supported ROCm PyTorch build, then use requirements-amd.txt.
# Apple Silicon picks up thinc-apple-ops (auto-installed via requirements.txt).
MODEL_DEVICE=auto

# Helps Apple MPS runs continue when a specific PyTorch op has no MPS kernel.
PYTORCH_ENABLE_MPS_FALLBACK=1

# Persisted dashboard theme classification. The embedding model selects this
# many candidates, then the cross-encoder reranks only those candidates.
THEME_CLASSIFICATION_CANDIDATES=3

# Raw top-score margin at or below which an answer is marked ambiguous.
# Cross-encoder scores are model-specific raw scores, not probabilities.
THEME_AMBIGUITY_SCORE_MARGIN=0.15

# Set false to use embedding cosine similarity as the explicit classification
# fallback. The selected method and model identity are persisted per response.
RERANKER_ENABLED=true
RERANKER_MODEL=zeroentropy/zerank-2-reranker

# Local generation defaults. Run `llama-server` from llama.cpp on this base URL.
DEFAULT_LLM_PROVIDER=llama.cpp
DEFAULT_LLM_MODEL=unsloth/gemma-4-E4B-it-GGUF:UD-Q4_K_XL
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080
LLAMA_CPP_API_KEY=no-key

# Full path to llama-server binary. Leave empty to use llama-server from PATH.
# Windows example: C:\tools\llama.cpp\llama-server.exe
LLAMA_CPP_SERVER_BIN=

# Model layers to offload to GPU. Use auto to fit available VRAM, all to require
# full offload, or 0 for CPU-only inference. Requires a CUDA-enabled llama.cpp build.
# Windows: check that ggml-cuda.dll exists in your llama.cpp folder before enabling.
LLAMA_CPP_N_GPU_LAYERS=auto

# Reserve about 2 GiB of VRAM when llama.cpp automatically fits GPU layers.
# This headroom prevents prompt processing and generation from exhausting VRAM.
LLAMA_ARG_FIT_TARGET=2048

# Run one concurrent llama.cpp request slot. More slots increase throughput,
# but each slot needs additional context/KV-cache memory.
LLAMA_ARG_N_PARALLEL=1

# Process at most 128 tokens per physical GPU batch. Smaller batches reduce
# temporary VRAM usage; larger batches may process long prompts faster.
LLAMA_ARG_UBATCH=128

# Process up to 512 records per anonymization batch. This is separate from
# llama.cpp; lower it if the anonymization pipeline runs out of RAM or VRAM.
ANONYMIZE_BATCH_SIZE=512
