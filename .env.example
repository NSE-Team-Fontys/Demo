# Optional: Hugging Face Hub token for higher rate limits and reliable downloads.
# Create a token at https://huggingface.co/settings/tokens
# Copy this file to `.env` and set your value (`.env` is gitignored).
HF_TOKEN=

# Optional model device override for PyTorch-backed local models.
# On Apple Silicon, use `mps` for the Mac GPU. There is no PyTorch `mpx` device.
MODEL_DEVICE=auto

# Helps Apple MPS runs continue when a specific PyTorch op has no MPS kernel.
PYTORCH_ENABLE_MPS_FALLBACK=1

# Local generation defaults. Run `llama-server` from llama.cpp on this base URL.
DEFAULT_LLM_PROVIDER=llama.cpp
DEFAULT_LLM_MODEL=unsloth/gemma-4-E4B-it-GGUF:UD-Q4_K_XL
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080
LLAMA_CPP_API_KEY=no-key

# Full path to llama-server binary. Leave empty to use llama-server from PATH.
# Windows example: C:\tools\llama.cpp\llama-server.exe
LLAMA_CPP_SERVER_BIN=

# Number of model layers to offload to GPU. Set to 99 to offload all layers.
# Leave at 0 for CPU-only inference. Requires a llama.cpp build with CUDA DLLs bundled.
# Windows: check that ggml-cuda.dll exists in your llama.cpp folder before enabling.
LLAMA_CPP_N_GPU_LAYERS=0
